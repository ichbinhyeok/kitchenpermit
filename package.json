{
  "name": "hood",
  "version": "1.0.0",
  "description": "Tailwind asset pipeline for the hood Spring Boot frontend",
  "scripts": {
    "build:tailwind": "tailwindcss -i ./src/main/tailwind/app.css -o ./src/main/resources/static/app.css --minify",
    "watch:tailwind": "tailwindcss -i ./src/main/tailwind/app.css -o ./src/main/resources/static/app.css --watch"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "daisyui": "^5.5.19",
    "tailwindcss": "^4.2.2"
  }
}
