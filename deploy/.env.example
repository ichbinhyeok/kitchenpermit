HOOD_SITE_ADDR=kitchenpermit.com
HOOD_SITE_BASE_URL=https://kitchenpermit.com
HOOD_SITE_NAME=KitchenPermit
HOOD_SITE_SUPPORT_EMAIL=support@kitchenpermit.com
APP_DATASOURCE_URL=jdbc:postgresql://aws-1-region.pooler.supabase.com:6543/postgres?sslmode=require&prepareThreshold=0
APP_DATASOURCE_DRIVER=org.postgresql.Driver
APP_DATASOURCE_USERNAME=postgres
APP_DATASOURCE_PASSWORD=replace-me
APP_DATASOURCE_HIKARI_MAXIMUM_POOL_SIZE=2
APP_DATASOURCE_HIKARI_MINIMUM_IDLE=0
APP_DATASOURCE_HIKARI_CONNECTION_TIMEOUT=30000
APP_HIBERNATE_DDL_AUTO=validate
HOOD_DATABASE_KEEPALIVE_ENABLED=true
HOOD_DATABASE_KEEPALIVE_INITIAL_DELAY_MS=60000
HOOD_DATABASE_KEEPALIVE_DELAY_MS=43200000
HOOD_BILLING_PROVIDER=abstract
HOOD_BILLING_ENVIRONMENT=sandbox
PADDLE_COMPANY_PRICE_ID=
PADDLE_API_KEY=
PADDLE_CLIENT_TOKEN=
PADDLE_WEBHOOK_SECRET=
PADDLE_WEBHOOK_TOLERANCE_SECONDS=300

HOOD_AXIS1_ASSET_STORAGE_DRIVER=filesystem
HOOD_AXIS1_R2_BUCKET=
HOOD_AXIS1_R2_ENDPOINT=
HOOD_AXIS1_R2_ACCESS_KEY_ID=
HOOD_AXIS1_R2_SECRET_ACCESS_KEY=
HOOD_AXIS1_R2_REGION=auto
HOOD_AXIS1_R2_KEY_PREFIX=axis1-reports

GEMINI_API_KEY=
SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_GOOGLE_CLIENT_ID=
SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_GOOGLE_CLIENT_SECRET=
SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_GOOGLE_SCOPE=openid,email,profile
JAVA_TOOL_OPTIONS=-XX:MaxRAMPercentage=75.0
