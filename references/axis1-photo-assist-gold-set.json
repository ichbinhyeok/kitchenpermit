          "notes": "Rooftop fan cleaning photo."
        },
        {
          "photoId": "grease-system-before",
          "fileName": "grease-system-before.jpg",
          "path": "frontend/public/axis1-test-photos/grease-system-before.jpg",
          "expectedSlotId": "grease-containment",
          "acceptedSlotIds": ["grease-containment", "hood-before"],
          "expectedTone": "record",
          "expectedNeedsVendorReview": true,
          "mustRemainSuggestionOnly": true,
          "notes": "Before/grease image; visual slot may be ambiguous."
        }
      ]
    },
