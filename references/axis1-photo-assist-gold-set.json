{
  "version": 1,
  "createdAt": "2026-05-01",
  "scope": "Axis 1 Photo Assist slot-suggestion and vendor-review validation. This is not a market validation set.",
  "notes": [
    "Repo fixtures are development QA assets, not product defaults or commercial sample assets.",
    "The gold set uses committed QA fixtures only; generated messy-synthetic images stay local-only and are not required for deterministic CI.",
    "Gold labels describe expected visual/product behavior. A filename-only mock is expected to fail some messy visual cases; that is useful because it establishes the gap Gemini should close."
  ],
  "cases": [
    {
      "id": "clean_baseline_fixture_set",
      "title": "Clean closeout baseline fixture set",
      "fixtureSource": "frontend/public/axis1-test-photos",
      "localOnly": false,
      "expectedOutcome": "clean",
      "reviewFocus": [
        "slot suggestions for common clean proof photos",
        "before/after ambiguity",
        "partial proof coverage boundaries"
      ],
      "photos": [
        {
          "photoId": "clean-hood-before-after",
          "fileName": "clean-hood-before-after.jpg",
          "path": "frontend/public/axis1-test-photos/clean-hood-before-after.jpg",
          "expectedSlotId": "hood-before",
          "acceptedSlotIds": ["hood-before", "hood-after"],
          "expectedTone": "before",
          "expectedNeedsVendorReview": true,
          "mustRemainSuggestionOnly": true,
          "notes": "Combined before/after image; either hood before or after is acceptable only as a suggestion."
        },
        {
          "photoId": "clean-filter-after-wash",
          "fileName": "clean-filter-after-wash.jpg",
          "path": "frontend/public/axis1-test-photos/clean-filter-after-wash.jpg",
          "expectedSlotId": "filter-bank",
          "acceptedSlotIds": ["filter-bank"],
          "expectedTone": "after",
          "expectedNeedsVendorReview": false,
          "mustRemainSuggestionOnly": true,
          "notes": "Cleaned filter bank proof."
        },
        {
          "photoId": "clean-exhaust-duct",
          "fileName": "clean-exhaust-duct.jpg",
          "path": "frontend/public/axis1-test-photos/clean-exhaust-duct.jpg",
          "expectedSlotId": "access-condition",
          "acceptedSlotIds": ["access-condition", "grease-containment"],
          "expectedTone": "issue",
          "expectedNeedsVendorReview": true,
          "mustRemainSuggestionOnly": true,
          "notes": "Duct/path image can support access or grease path, but should not imply full path completion."
        },
        {
          "photoId": "hood-filters-installed",
          "fileName": "hood-filters-installed.jpg",
          "path": "frontend/public/axis1-test-photos/hood-filters-installed.jpg",
          "expectedSlotId": "filter-bank",
          "acceptedSlotIds": ["filter-bank"],
          "expectedTone": "after",
          "expectedNeedsVendorReview": false,
          "mustRemainSuggestionOnly": true,
          "notes": "Installed hood filters."
        },
        {
          "photoId": "kitchen-exhaust-fan",
          "fileName": "kitchen-exhaust-fan.jpg",
          "path": "frontend/public/axis1-test-photos/kitchen-exhaust-fan.jpg",
          "expectedSlotId": null,
          "acceptedSlotIds": [null],
          "expectedTone": "unknown",
          "expectedNeedsVendorReview": true,
          "mustRemainSuggestionOnly": true,
          "notes": "Looks like an unrelated wall-mounted appliance, not a hood/rooftop fan proof photo."
        },
        {
          "photoId": "grease-removed-bucket",
          "fileName": "grease-removed-bucket.jpg",
          "path": "frontend/public/axis1-test-photos/grease-removed-bucket.jpg",
          "expectedSlotId": "grease-containment",
          "acceptedSlotIds": ["grease-containment"],
          "expectedTone": "record",
          "expectedNeedsVendorReview": true,
          "mustRemainSuggestionOnly": true,
          "notes": "Grease removed/contained, but not cleaned-area proof by itself."
        }
      ]
    },
